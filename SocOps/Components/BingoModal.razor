<div class="party-modal-overlay">
    <div class="party-modal-card">
        <div class="modal-crown" aria-hidden="true">🏆 ⚽ 🍺</div>
        <h2>CHAMPION BINGO!</h2>
        <p>Your line is complete. The crowd is roaring and confetti is flying.</p>

        <button id="keep-playing-btn" @onclick="HandleDismiss" class="party-button modal-button">
            Keep The Party Going
        </button>
    </div>
</div>

@code {
    [Inject]
    private IJSRuntime JS { get; set; } = null!;

    [Parameter]
    public EventCallback OnDismiss { get; set; }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await JS.InvokeVoidAsync("partyEffects.burst", "bingo");
        }
    }

    private async Task HandleDismiss()
    {
        await JS.InvokeVoidAsync("partyEffects.pulseButton", "keep-playing-btn");
        await JS.InvokeVoidAsync("partyEffects.burst", "kickoff");
        await OnDismiss.InvokeAsync();
    }
}
