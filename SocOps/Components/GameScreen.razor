@using SocOps.Models

<div class="match-screen">
    <header class="score-header">
        <button id="reset-btn" @onclick="HandleReset" class="party-button secondary-button">Exit Match</button>
        <h1>Soc Ops Cup</h1>
        <div class="score-pill">FAN BINGO</div>
    </header>

    <p class="chant-banner">Tap each fan match and build your winning streak.</p>

    @if (HasBingo)
    {
        <div class="goal-banner">
            GOAL! You scored a full line. Party mode unlocked!
        </div>
    }

    <div class="board-wrap">
        <BingoBoard
            Board="@Board"
            WinningSquareIds="@WinningSquareIds"
            OnSquareClick="@OnSquareClick" />
    </div>
</div>

@code {
    [Inject]
    private IJSRuntime JS { get; set; } = null!;

    [Parameter]
    public List<BingoSquareData> Board { get; set; } = new();

    [Parameter]
    public HashSet<int> WinningSquareIds { get; set; } = new();

    [Parameter]
    public bool HasBingo { get; set; }

    [Parameter]
    public EventCallback<int> OnSquareClick { get; set; }

    [Parameter]
    public EventCallback OnReset { get; set; }

    private async Task HandleReset()
    {
        await JS.InvokeVoidAsync("partyEffects.pulseButton", "reset-btn");
        await JS.InvokeVoidAsync("partyEffects.burst", "reset");
        await OnReset.InvokeAsync();
    }
}
