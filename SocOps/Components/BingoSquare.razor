@using SocOps.Models

<button
    @onclick="HandleClick"
    disabled="@Square.IsFreeSpace"
    class="@GetCssClasses()"
    aria-pressed="@Square.IsMarked"
    aria-label="@(Square.IsFreeSpace ? "Free space" : Square.Text)">
    @if (Square.IsFreeSpace)
    {
        <span class="square-icon" aria-hidden="true">⚽</span>
    }
    <span class="wrap-break-word hyphens-auto">@Square.Text</span>
    @if (Square.IsMarked && !Square.IsFreeSpace)
    {
        <span class="square-check" aria-hidden="true">GOAL</span>
    }
</button>

@code {
    [Inject]
    private IJSRuntime JS { get; set; } = null!;

    [Parameter]
    public BingoSquareData Square { get; set; } = null!;

    [Parameter]
    public bool IsWinning { get; set; }

    [Parameter]
    public EventCallback OnClick { get; set; }

    private string GetCssClasses()
    {
        var baseClasses = "bingo-square";

        var stateClasses = Square.IsMarked
            ? IsWinning
                ? "is-winning"
                : "is-marked"
            : "is-open";

        var freeSpaceClasses = Square.IsFreeSpace ? "is-free-space" : "";

        return $"{baseClasses} {stateClasses} {freeSpaceClasses}";
    }

    private async Task HandleClick()
    {
        await OnClick.InvokeAsync();

        if (!Square.IsFreeSpace)
        {
            await JS.InvokeVoidAsync("partyEffects.burst", "tile");
        }
    }
}
