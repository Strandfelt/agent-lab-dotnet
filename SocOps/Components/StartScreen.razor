<section class="kickoff-screen">
    <div class="stadium-lights"></div>
    <div class="kickoff-card">
        <p class="match-tag">FIFA PARTY MODE</p>
        <h1 class="kickoff-title">Soc Ops Cup</h1>
        <p class="kickoff-subtitle">Stadium cheers, soccer balls, confetti, and party pints all night.</p>

        <div class="party-icons" aria-hidden="true">
            <span>⚽</span>
            <span>🎊</span>
            <span>🍺</span>
            <span>🏆</span>
            <span>⚽</span>
        </div>

        <div class="rules-card">
            <h2>Match Rules</h2>
            <ul>
                <li>Find fans who match each square.</li>
                <li>Tap each match to lock it in.</li>
                <li>Score five in a row and claim the cup.</li>
            </ul>
        </div>

        <button id="kickoff-btn" @onclick="HandleStart" class="party-button kickoff-button">
            Kick Off The Party
        </button>
    </div>
</section>

@code {
    [Inject]
    private IJSRuntime JS { get; set; } = null!;

    [Parameter]
    public EventCallback OnStart { get; set; }

    private async Task HandleStart()
    {
        await JS.InvokeVoidAsync("partyEffects.pulseButton", "kickoff-btn");
        await JS.InvokeVoidAsync("partyEffects.burst", "kickoff");
        await OnStart.InvokeAsync();
    }
}
